{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Legends Awakened Launcher",
  "version": "0.1.11",
  "identifier": "com.legendsawakened.launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Legends Awakened",
        "width": 940,
        "height": 800,
        "minWidth": 940,
        "minHeight": 800,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
