{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Legends Awakened Launcher",
  "version": "0.1.38",
  "identifier": "com.legendsawakened.launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Legends Awakened",
        "width": 1120,
        "height": 700,
        "minWidth": 1120,
        "minHeight": 700,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/DoubtfulHermit/legends-launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzNTNBNTMxREJENEIwRUQKUldUdHNOVGJNYVZUMHdCYThuQ0hFLzdHakl3N0VPM3cxTHpCbHZ6RDNZM01FaExVOGdRTlJSMHgK"
    }
  }
}
